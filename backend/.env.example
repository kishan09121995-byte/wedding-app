# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5433/facedb

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=8000
ENVIRONMENT=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000,https://bim-nexus-9dc9d.web.app

# Google Drive Integration (optional)
GOOGLE_DRIVE_CREDENTIALS_JSON=/path/to/credentials.json

# Face Recognition Model
# Options: Facenet512, VGGFace, OpenFace, DeepID, ArcFace, Dlib
FACE_MODEL=Facenet512

# Similarity Threshold (0.0-1.0)
# Lower = more matches, Higher = fewer but more confident matches
SIMILARITY_THRESHOLD=0.6
